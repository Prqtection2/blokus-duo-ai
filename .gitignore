/target
**/*.rs.bk
Cargo.lock.bak

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
build/
dist/
*.so
*.pyd

# WASM web build artifacts. The canonical main.js/style.css live in
# python/blokus_harness/gui/static/ and are copied into web/ at build time;
# pkg/ is generated by wasm-bindgen. Only web/index.html, web/backend-wasm.js
# and web/serve.py are source.
web/pkg/
web/main.js
web/style.css

# Saved GUI positions (diagnostic dumps)
python/diagnostics/positions/*.json
